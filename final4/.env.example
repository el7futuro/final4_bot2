# Final 4 - Environment Configuration

# ============================================
# DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql+asyncpg://final4:final4_password@localhost:5432/final4
DATABASE_URL_SYNC=postgresql://final4:final4_password@localhost:5432/final4

# Для Alembic
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=final4
POSTGRES_PASSWORD=final4_password
POSTGRES_DB=final4

# ============================================
# CACHE (Redis)
# ============================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379

# ============================================
# TELEGRAM BOT
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Получить: https://t.me/BotFather

# ============================================
# VK BOT
# ============================================
VK_BOT_TOKEN=your_vk_bot_token_here
VK_GROUP_ID=your_vk_group_id
# Получить: https://vk.com/dev

# ============================================
# DISCORD BOT
# ============================================
DISCORD_BOT_TOKEN=your_discord_bot_token_here
# Получить: https://discord.com/developers/applications

# ============================================
# API (FastAPI)
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=your_super_secret_key_change_in_production
API_DEBUG=true

# JWT
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ============================================
# LIMITS
# ============================================
FREE_DAILY_MATCHES=3
PREMIUM_DAILY_MATCHES=10
PRO_DAILY_MATCHES=unlimited
